<!--script to allow adding items to the cart-->
<script>
    function displayCustomMessage(title, message) {
        let msgBox = document.getElementById('custom-message-box');

        if (!msgBox) {
            msgBox = document.createElement('div');
            msgBox.id = 'custom-message-box';
            msgBox.style.cssText =
                'position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); ' +
                'background-color: #333; color: white; padding: 20px; border-radius: 8px; ' +
                'z-index: 1000; text-align: center; opacity: 0; transition: opacity .3s;';
            document.body.appendChild(msgBox);
        }

        msgBox.innerHTML =
            `<h3>${title}</h3>
             <p>${message}</p>
             <button id="msg-ok-btn">OK</button>`;

        document.getElementById("msg-ok-btn").onclick = () => {
            msgBox.style.opacity = '0';
        };

        msgBox.style.opacity = '1';
    }


    async function handleAddToCartClick() {

        const product = this.closest('.product-content');
        const productId = product.getAttribute('data-product-id');
        const title = product.querySelector('h2').textContent.trim();
        const sizeSelect = product.querySelector('.product-size-select');

        if (!sizeSelect.value) {
            displayCustomMessage("Select Size", "Please select a size before adding.");
            return;
        }

        const [size, priceText] = sizeSelect.value.split(" - ");
        const price = parseFloat(priceText.replace("R", "").replace(",", "."));

        const item = {
    ProductId: productId,
    Title: title,
    Size: size,
    Price: price,
    Quantity: 1,
    Image: product.querySelector('img').src
        };

        const token = document.querySelector("input[name='__RequestVerificationToken']").value;

        try {
            const response = await fetch("@Url.Action("AddItemToCart", "Home")", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token
                },
                body: JSON.stringify(item)
            });

            if (response.ok) {
                displayCustomMessage("Added!", `${title} (${size}) added to cart.`);
            } else {
                displayCustomMessage("Error", "Server rejected the request.");
            }

        } catch {
            displayCustomMessage("Network Error", "Could not connect.");
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".add-to-cart-btn")
            .forEach(btn => btn.addEventListener("click", handleAddToCartClick));
    });
</script>

