<!--internal styling-->
<style>
    .header-container {
        width: 100%;
        height: 40vh;
        display: block;
        background-image: url("/images/about-background.jpg");
        background-size: cover;
        background-repeat: no-repeat;
        color: white;
    }
    .header-container h1 {
            text-align: center;
            margin-top: 8rem;
    }
    .product-label h1 {
        text-align: center;
    }
    .product-label p {
        text-align: center;
    }
    .product-container {
        width: 100%;
        height: 60vh; 
        background-color: white;
        display: flex; 
        flex-wrap: wrap; 
        justify-content: center;
        text-align: center;
        padding: 20px 0;
        height: auto; 
    }
    .product-content {
        width: 15%; 
        height: 60vh;
        border-radius: 10px;
        background-color: red;
        margin: 15px 2%; 
        color: black;
        padding-top: 10px;
    }
    .product-content hr {
            width: 90%;
            border-color: rgba(255, 255, 255, 0.5);
    }
    .product-content img {
            width: 100%;
            height: 30vh;
            justify-content: center;
            object-fit: contain;
    }
    .product-content h2 {
            font-size: 18px;
     }
    .product-content select {
            width: 60%;
            height: 5vh;
            border-color: black;
            background-color: transparent;
            border-radius: 5px;
            margin-bottom: 1rem;
            color: black; 
            border: 1px solid white; 
    }
    .product-content select:hover {
                color: black;
                border-color: white;
                transition: 1s;
    }
    .product-content option {
            background-color: red;
            color: white; 
    }
    .product-content button {
            width: 60%;
            height: 5vh;
            background-color: transparent;
            border-radius: 5px;
            cursor: pointer;
            border: 1px solid white; 
    }
    .product-content button a {
                color: white;
                text-decoration: none;
                display: block;
                line-height: 5vh;
    }
    .product-content button:hover {
                background-color: white;
                transition: 1s;
    }
    .product-content button:hover a {
                    color: red; 
    }

    .footer-container {
        font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
        color: white;
        background-color: black;
        width: 100%;
        height: 40vh;
        justify-content: center;
        display: flex;
        flex-direction: column;
        margin-top: 5rem;
        text-align: center;
        padding: 20px 0;
    }

    .footer-icons {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        font-size: 20px;
    }

        .footer-icons a {
            color: white;
        }

            .footer-icons a:hover i {
                font-size: 25px;
                transition: 0.3s;
                color: red;
            }

    /*mobile responsiveness*/
    @@media (max-width: 992px) {
    .header-container h1{
     margin-top: 6rem;
    }
    .product-container {
        flex-direction: column; 
        height: auto;
    }
    .product-content {
        width: 90%; 
        height: auto; 
        margin: 15px auto; 
        padding-bottom: 10px;
    }
    .product-content img {
            height: 35vh;
    }
    .product-content select,
    .product-content button {
            width: 60%; 
            margin-left: auto;
            margin-right: auto;
    }
    .footer-container {
        height: auto;
        padding: 30px 10px;
        margin-top: 3rem;
    }
    }
</style>

