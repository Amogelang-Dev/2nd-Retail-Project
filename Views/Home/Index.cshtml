@{
    ViewData["Title"] = "Home Page";
}

<!--internal styling-->
<style>
    /*header*/
    .header {
        height: 100vh;
        width: 100%;
        position: relative;
        color: white;
        font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
    }
    .text-box {
        width: 90%;
        color: #fff;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        text-align: center;
    }
    .text-box h1 {
            font-size: 62px;
    }
    .text-box p {
            margin: 10px 0 40px;
            font-size: 14px;
            color: #fff;
    }
    .text-box button {
            display: inline-block;
            text-decoration: none;
            color: #fff;
            border: 1px solid #fff;
            border-radius: 10px;
            padding: 12px 34px;
            font-size: 13px;
            background: transparent;
            position: relative;
            cursor: pointer;
    }
    .text-box button:hover {
                border: 1px solid lightblue;
                background-color: red;
                transition: 1s;
    }

    /*video background*/
    .video {
        margin: 0;
        overflow: hidden;
        height: 100vh;
    }
    .video-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        object-fit: cover;
        z-index: -1;
    }
    .content {
        position: relative;
        z-index: 1;
        color: white;
        text-align: center;
        padding: 20px;
    }
    .text-box a {
        text-decoration: none;
        color: white;
    }

    /*products section style*/
    .products-header {
        color: black;
        font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
    }
    .products-header h1 {
            text-align: center;
    }
    .products-header p {
            text-align: center;
            margin-top: 0;
    }

    /* Desktop View: Inline flex layout for products */
    .products-container {
        background-color: white;
        width: 100%;
        height: 50vh;
        display: flex; 
        flex-wrap: wrap;
        justify-content: center;
    }
    .products-content {
        background-color: red;
        width: 20%;
        height: 40vh;
        margin: 0 1.5%; 
        border-radius: 15px;
    }
    .products-content img {
            justify-content: center;
            width: 100%;
            height: 30vh;
            margin-top: 0;
            object-fit: cover; /* Added for image scaling */
            border-top-left-radius: 15px;
            border-top-right-radius: 15px;
    }
    .products-content hr {
            width: 90%;
    }
    .products-content h2 {
            text-align: center;
            font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
            color: white; /* Added color for readability on red background */
            font-size: 16px;
            margin-top: 10px;
    }
    .products-container button {
        font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
        margin-top: 2rem;
        color: black;
        border-radius: 5px;
        background-color: transparent;
        width: 15%;
        height: 5vh;
        border: 1px solid black;
        cursor: pointer;
    }
    .products-container button:hover {
            background-color: red;
            color: white;
            transition: 0.3s;
    }
    .products-container button a {
            text-decoration: none;
            color: black;
            display: block;
            line-height: 5vh; /* Center text vertically in button */
    }
    .products-container button:hover a {
            color: white;
            background-color: transparent; /* Prevent background change on inner 'a' tag */
            transition: 0.3s;
    }
    /* Contact Section Styles */
    .contact-container {
        width: 70%;
        height: 35vh;
        border-radius: 10px;
        background-image: url("images/chili.jpg");
        background-repeat: no-repeat;
        background-size: cover;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
        margin: 3rem auto 0 auto; /* Center with auto margin */
        text-align: center; /* Center text inside the container */
        padding: 20px;
    }
    .contact-container h1 {
            text-align: center;
            margin-top: 0; /* Adjusted for centering */
            margin-left: 0;
            font-size: 28px;
    }
    .contact-container button {
            height: 5vh;
            width: 15%;
            border-radius: 5px;
            margin-bottom: 0;
            color: white;
            border: 1px solid white;
            background-color: transparent;
            cursor: pointer;
            text-decoration: none;
            font-size: 16px;
            padding: 0;
    }
    .contact-container button:hover {
                background-color: red;
                transition: 0.3s;
    }
    .contact-container button a {
                text-decoration: none;
                color: white;
                display: block;
                line-height: 5vh;
    }
    /* Footer Section Styles */
    .footer-container {
        font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
        color: white;
        background-color: black;
        width: 100%;
        height: 40vh;
        justify-content: center;
        display: flex;
        flex-direction: column;
        margin-top: 5rem;
        text-align: center;
        padding: 20px 0;
    }
    .footer-icons {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        font-size: 20px;
    }
    .footer-icons a {
            color: white;
            text-decoration: none;
    }
    .footer-icons a:hover i {
                font-size: 25px;
                transition: 0.3s;
                color: red;
    }
    .footer-icons i {
            transition: 0.3s;
    }
    /*mobile responsiveness*/
    @@media (max-width: 768px) {
    .products-container{
        flex-direction: column;
        height: auto; 
    }
    .products-content {
        width: 90%;
        height: 45vh; 
        margin: 20px auto; 
    }
    .products-content img {
            height: 30vh;
    }
    .products-container button {
        width: 50%; 
        margin: 1rem auto 3rem auto; 
    }
    .contact-container {
        width: 90%;
        height: auto; 
        padding: 30px 10px;
        margin: 3rem auto;
    }
    .contact-container h1 {
            font-size: 24px;
    }
    .contact-container button {
            width: 40%;
    }
    .text-box h1 {
        font-size: 40px;
    }
    .footer-container {
        height: auto;
        padding: 30px 10px;
    }
    .footer-icons {
        margin: 15px 0;
    }

    }
</style>


