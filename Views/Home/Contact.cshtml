<!--internal styling-->
<style>
/* Base Styles (Desktop) */
.header-container {
    width: 100%;
    height: 40vh;
    display: block;
    background-image: url("/images/about-background.jpg");
    background-size: cover;
    background-repeat: no-repeat;
    color: white;
}
.header-container h1 {
    text-align: center;
    margin-top: 8rem;
}
    .footer-container {
        font-family: 'Poppins', sans-serif, 'Roboto Condensed', sans-serif;
        color: white;
        background-color: black;
        width: 100%;
        height: 40vh;
        justify-content: center;
        display: flex;
        flex-direction: column;
        margin-top: 5rem;
        text-align: center;
        padding: 20px 0;
    }
    .footer-icons {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        font-size: 20px;
    }
    .footer-icons a {
            color: white;
    }
    .footer-icons a:hover i {
                font-size: 25px;
                transition: 0.3s;
                color: red;
    }
.info-container{
    width: 100%;
    height: 40vh; 
    margin-top: 4rem;
    background-color: white;
    display: flex; 
    flex-wrap: wrap;
    justify-content: center;
    height: auto;
}
.info-content{
    width: 25%; 
    height: 40vh; 
    background-color: white;
    margin: 0 2.5%; 
    padding: 10px;
}
.info-content p:hover{
    color: red;
}

/* clickable email */
.info-content a {
    color: black; 
    text-decoration: none;
    transition: 0.3s;
}
.info-content a:hover {
    color: red; 
    text-decoration: none; 
}
.info-content p:hover{
    color: black; 
}
.map{
    margin: 3rem auto; 
    width: 80%;
    height: 40vh;
    background-color: white;
    border-radius:10px;
    justify-content: center;
}
.map iframe{
    width: 100%;
    height: 40vh;
    border-radius: 10px;
    transition: 1s;
}
.map iframe:hover{
    height: 45vh;
    transition: 1s;
}
/*mobile responsiveness*/
@@media (max-width: 992px) { 
    .header-container h1 {
        margin-top: 6rem;
    }
    .info-container{
        flex-direction: column; 
        height: auto;
    }
    .info-content{
        width: 90%; 
        height: auto; 
        margin: 15px auto; 
        padding: 20px;
        border: 1px solid #eee; 
        border-radius: 5px;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
    }
    .info-content h2, 
    .info-content p {
        text-align: center;
    }
    .info-content a {
        display: block; 
        text-align: center;
    }
    .map{
        width: 90%; 
        height: 35vh;
        margin: 2rem auto;
    }
    .map iframe{
        height: 35vh; 
    }
    .footer-container{
        margin-top: 3rem;
        height: auto;
    }
}
</style>

